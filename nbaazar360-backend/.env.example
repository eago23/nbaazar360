NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nbaazar360

# JWT
JWT_SECRET=nbaazar360-super-secret-key-change-me
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Cloudinary (File Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for QR codes and email links)
FRONTEND_URL=http://localhost:3000

# Email (SMTP Configuration - OPTIONAL FOR DEVELOPMENT)
# For development: Leave these blank to skip email sending (emails will just log to console)
# For production: Configure SMTP to send real emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nbaazar360.al
ADMIN_EMAIL=admin@bashkiatirana.gov.al

# Feature Flags
ADMIN_EMAIL_NOTIFICATIONS=false
VENDOR_EMAIL_NOTIFICATIONS=false
